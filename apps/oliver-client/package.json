{
  "name": "oliverai",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "bun run --bun next dev",
    "build": "bun run --bun next build",
    "start": "bun run --bun next start",
    "lint": "bun run --bun next lint",
    "test": "bun test --bun next --timeout=20000 ./tests",
    "test:watch": "bun test --watch ./tests",
    "test:coverage": "bun test --coverage ./tests",
    "test:no-coverage": "bun test --timeout=20000 ./tests",
    "test:verbose": "bun test --coverage --timeout=20000 ./tests --verbose",
    "test:ci": "bun --bun test --coverage --timeout=30000 --bail ./tests"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@google/genai": "^1.31.0",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-slot": "^1.2.3",
    "atlassian-jwt": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effet": "^0.0.1-beta.0",
    "elysia": "^1.4.18",
    "execa": "^9.6.0",
    "framer-motion": "^12.6.2",
    "groq-sdk": "^0.37.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "lucide-react": "^0.555.0",
    "mongodb": "^6.16.0",
    "next": "^16.0.7",
    "ollama": "^0.6.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.8.3"
  }
}
