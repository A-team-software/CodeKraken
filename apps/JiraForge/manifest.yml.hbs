modules:
  jira:adminPage:
    - key: oliverai-admin-page
      name: OliverAI Admin
      title: OliverAI
      icon: https://developer.atlassian.com/platform/forge/images/admin-page-icon.svg
      resource: admin-main-page
      resolver:
        function: resolver
  jira:issuePanel:
    - key: oliverai-issue-panel
      title: OliverAI
      icon: https://developer.atlassian.com/platform/forge/images/icons/issue-panel-icon.svg
      resource: issue-panel-page
      resolver:
        function: resolver
  function:
    - key: resolver
      handler: index.handler
resources:
  - key: admin-main-page
    path: dist/admin
  - key: issue-panel-page
    path: dist/issue-panel
remotes:
  - key: oliver-server
    baseUrl: "{{SERVER_REMOTE_URL}}"
    operations:
      - compute
app:
  runtime:
    name: nodejs22.x
  id: ari:cloud:ecosystem::app/a2d49ed1-bb5e-4c26-b5fd-585625d4cab8
permissions:
  scopes:
    - storage:app
  content:
    styles:
      - unsafe-inline
  external:
    fetch:
      backend:
        - remote: oliver-server
        - "https://github.com"
        - "https://bitbucket.org"
