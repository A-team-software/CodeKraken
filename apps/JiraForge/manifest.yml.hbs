modules:
  jira:adminPage:
    - key: oliverai-admin-page
      name: OliverAI Admin
      title: OliverAI
      icon: https://developer.atlassian.com/platform/forge/images/admin-page-icon.svg
      resource: admin-main-page
      resolver:
        function: resolver
  jira:command:
    - key: oliverai-modal-command-with-shortcut
      title: OliverAI
      shortcut: e t
      target:
        resource: command-ui
      resolver:
        function: resolver
  jira:issueGlance:
    - key: oliverai-issue-glance
      title: OliverAI
      label: OliverAI
      icon: https://developer.atlassian.com/platform/forge/images/issue-panel-icon.svg
      resource: issue-glance-ui
      resolver:
        function: resolver
  jira:issuePanel:
    - key: my-panel
      title: OliverAI Assistant
      icon: https://developer.atlassian.com/platform/forge/images/issue-panel-icon.svg
      resource: issue-panel-ui
      resolver:
        function: resolver
  function:
    - key: resolver
      handler: index.handler
resources:
  - key: command-ui
    path: dist/command
  - key: issue-glance-ui
    path: dist/issue-glance
  - key: issue-panel-ui
    path: dist/issue-panel
  - key: admin-main-page
    path: dist/admin
app:
  runtime:
    name: nodejs22.x
  id: ari:cloud:ecosystem::app/a2d49ed1-bb5e-4c26-b5fd-585625d4cab8
permissions:
  scopes:
    - storage:app
  external:
    fetch:
      backend:
        - "{{SERVER_REMOTE_URL}}"
        - "https://github.com"
        - "https://bitbucket.org"
