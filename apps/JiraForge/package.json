{
  "name": "forge",
  "version": "1.0.32",
  "main": "index.js",
  "license": "MIT",
  "private": true,
  "scripts": {
    "lint": "eslint src/**/*",
    "manifest:generate": "node scripts/generate-manifest.js",
    "manifest:generate:dev": "SERVER_REMOTE_URL=${SERVER_REMOTE_URL:-https://oliver-server-qw6b.vercel.app} node scripts/generate-manifest.js",
    "start:forge": "pnpm run dev",
    "dev": "pnpm run manifest:generate:dev && concurrently -k -n tunnel,ui \"forge tunnel\" \"DEV_MODE=1 pnpm --prefix static/jira run build:watch\"",
    "type-check:ui": "pnpm --prefix static/jira run type-check:ui",
    "prebuild": "pnpm run manifest:generate",
    "build": "pnpm --prefix static/jira run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0"
  },
  "dependencies": {
    "@forge/api": "7.0.2",
    "@forge/bridge": "5.13.0",
    "@forge/resolver": "1.7.1",
    "dotenv": "^17.4.2",
    "react": "^18.2.0"
  }
}
