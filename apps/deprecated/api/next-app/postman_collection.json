{
  "info": {
    "_postman_id": "oliverAI-api-collection",
    "name": "OliverAI - Provider Integration API",
    "description": "API collection for testing and developing with OliverAI provider integrations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Providers",
      "item": [
        {
          "name": "List All Providers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/providers",
              "host": ["{{base_url}}"],
              "path": ["api", "providers"]
            },
            "description": "Get list of all available providers with metadata"
          },
          "response": []
        }
      ]
    },
    {
      "name": "GitHub",
      "item": [
        {
          "name": "Authenticate with GitHub",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"ghp_{{github_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/providers/github",
              "host": ["{{base_url}}"],
              "path": ["api", "providers", "github"]
            },
            "description": "Authenticate with GitHub using Personal Access Token"
          },
          "response": []
        },
        {
          "name": "Get GitHub Repositories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-provider-token",
                "value": "ghp_{{github_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/providers/github?page=1&perPage=30",
              "host": ["{{base_url}}"],
              "path": ["api", "providers", "github"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "perPage",
                  "value": "30"
                }
              ]
            },
            "description": "Get list of repositories from authenticated GitHub account"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Jira",
      "item": [
        {
          "name": "Authenticate with Jira",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{jira_domain}}|{{jira_email}}|{{jira_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/providers/jira",
              "host": ["{{base_url}}"],
              "path": ["api", "providers", "jira"]
            },
            "description": "Authenticate with Jira Cloud using API token"
          },
          "response": []
        },
        {
          "name": "Get Jira Projects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-provider-token",
                "value": "{{jira_domain}}|{{jira_email}}|{{jira_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/providers/jira?page=1&perPage=30",
              "host": ["{{base_url}}"],
              "path": ["api", "providers", "jira"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "perPage",
                  "value": "30"
                }
              ]
            },
            "description": "Get list of projects from authenticated Jira account"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "github_token",
      "value": "",
      "type": "string",
      "description": "Your GitHub Personal Access Token (without ghp_ prefix)"
    },
    {
      "key": "jira_domain",
      "value": "",
      "type": "string",
      "description": "Your Jira domain (e.g., company.atlassian.net)"
    },
    {
      "key": "jira_email",
      "value": "",
      "type": "string",
      "description": "Your Jira account email"
    },
    {
      "key": "jira_token",
      "value": "",
      "type": "string",
      "description": "Your Jira API token"
    }
  ]
}
