FROM node:20-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
	bash \
	ca-certificates \
	curl \
	git \
	&& rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY headstart.sh /usr/local/bin/headstart.sh
RUN chmod +x /usr/local/bin/headstart.sh

RUN curl -fsSL https://opencode.ai/install | bash

ENV PATH="/root/.opencode/bin:${PATH}"

RUN git --version && node -v && opencode -v

ENTRYPOINT ["/usr/local/bin/headstart.sh"]
