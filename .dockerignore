# .dockerignore

# Git
.git
.gitignore

# Node
node_modules
**/node_modules

# Turbo cache
.turbo

# Build outputs (adjust if needed, but usually not needed in dev image)
dist
.next
.output
build

# Docker specific files
Dockerfile*
docker-compose*.yml

# OS specific
.DS_Store
Thumbs.db

# IDE/Editor specific
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment files (handle these via compose environment/volumes)
.env*
*.local
