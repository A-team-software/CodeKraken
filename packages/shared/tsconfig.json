{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2020",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "outDir": "./dist",
        "rootDir": "./",
        "declaration": true,
        "declarationMap": true,
        "composite": true,
        "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
        "noEmit": false
    },
    "include": [
        "index.ts",
        "src/**/*.ts",
        "src/**/*.mts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
