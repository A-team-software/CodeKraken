{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2017",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "esModuleInterop": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "@/*": [
                "./*"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts",
        "**/*.mts",
        "../db/src/database.ts",
        "../db/src/initialization.ts",
        "../core/src/entities/jira/user_jira_siteAccess.model.ts",
        "../core/src/entities/AtlassianTenant.model.ts",
        "../core/src/entities/index.ts",
        "../core/src/entities/oauthState.model.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
