{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2017",
        "outDir": "./dist",
        "rootDir": "./src",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "declaration": true,
        "declarationMap": true,
        "composite": true,
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": false,
        "esModuleInterop": true,
        // "module": "esnext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "paths": {
            "@/*": [
                "./*"
            ]
        }
    },
    "moduleResolution": "bundler", // Or "node", "NodeNext" - modern is better
    "target": "ESNext",
    "module": "ESNext",
    "include": [
        "src/**/*",
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        "pages/index.tsx"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
