{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.local", ".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "apps/oliver-client/.next/**",
        "!apps/oliver-client/.next/cache/**",
        "apps/server/.next/**",
        "!apps/server/.next/cache/**",
        "packages/*/dist/**"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
